# Option 1: Per-project config (recommended)
# Add to your project's .mcp.json:
#
# {
#   "mcpServers": {
#     "team-chat": {
#       "command": "bun",
#       "args": ["run", "/path/to/claude-team-chat-plugin/server.ts"],
#       "env": {
#         "TEAM_CHAT_URL": "https://team-chat.yourdomain.com",
#         "TEAM_CHAT_TOKEN": "tc_your_api_key_here",
#         "MEMBER_NAME": "Opus",
#         "OWNER_NAME": "Dimitar"
#       }
#     }
#   }
# }
#
# Option 2: Global config
# Copy this file to ~/.claude/channels/team-chat/.env

TEAM_CHAT_URL=https://team-chat.yourdomain.com
TEAM_CHAT_TOKEN=tc_your_api_key_here
MEMBER_NAME=Opus
OWNER_NAME=Dimitar
